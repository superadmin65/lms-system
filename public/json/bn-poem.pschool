{"label":"ছোটদের ছড়া","id":"bn-poem","img":"reading","lockAfter":5,"list":[{"id":"100","type":"passage","label":"আতা গাছে তোতা পাখি","data":{"title":"আতা গাছে তোতা পাখি","text":[{"type":"poem","text":"আতা গাছে তোতা পাখি\nডালিম গাছে মৌ,\nএতো ডাকি তবুও কেন\nকওনা কথা বউ ?"}]}},{"id":"200","type":"passage","label":"চাঁদ উঠেছে ফুল ফুটেছে","data":{"title":"চাঁদ উঠেছে ফুল ফুটেছে","text":[{"type":"poem","text":"চাঁদ উঠেছে ফুল ফুটেছে\nকদম তলায় কে?\nহাতি নাচছে ঘোড়া নাচছে\nসোনামুনির বে."}]}},{"id":"300","type":"passage","label":"শিল পড়া","data":{"title":"শিল পড়া","text":[{"type":"poem","text":"শিল পড়ে টুপটাপ\nখোকা খুকু চুপচাপ ,\nশিল পড়া থামল ,\nআঙিনায় নামল ,\nহুটোপুটি, ছুটোছুটি,\nসারাবেলা দুপদাপ।"}]}},{"id":"400","type":"passage","label":"খোকন খোকন","data":{"title":"খোকন খোকন","text":[{"type":"poem","text":"খোকন খোকন করে মায়,\nখোকন গেছে কাদের নাই ,\nসাতরা কাকে দাঁড় বাই ,\nখোকনরে তুই ঘরে আই।"}]}},{"id":"500","type":"passage","label":"কাঠবেড়ালি","data":{"title":"কাঠবেড়ালি","text":[{"type":"poem","text":"কাঠবেড়ালি, কাঠবেড়ালি\nকাপড় কেচে দে ,\nতোর বিয়েতে নাচতে যাব\nঝুমকো কিনে দে।"}]}},{"id":"600","type":"passage","label":"বাক বাকুম পায়রা","data":{"title":"বাক বাকুম পায়রা","text":[{"type":"poem","text":"বাক বাকুম পায়রা\nমাথায় দিয়ে টায়রা।\nবৌ সাজাবে কাল কি\nচড়বে সোনার পালকি।"}]}},{"id":"700","type":"passage","label":"তাঁতীর বাড়ি","data":{"title":"তাঁতীর বাড়ি","text":[{"type":"poem","text":"তাঁতীর বাড়ি\nব্যাঙের বাসা ,\nকোলা ব্যাঙের ছা\nখায় - দায় গান গায় ,\nতাই রে নাই রে না।"}]}},{"id":"800","type":"passage","label":"রামধনু","data":{"title":"রামধনু","text":[{"type":"poem","text":"আকাশের গায়ে কি বা রামধনু খেলে,\nদেখে চেয়ে কত লোকে সব কাজ ফেলে,\nতাই দেখে খুঁতধরা বুড়ো কয় চটে,\nদেখছ কি, এই রঙ পাকা নয় মোটে ॥"}]}},{"id":"900","type":"passage","label":"নোটন নোটন পায়রাগুলি","data":{"title":"নোটন নোটন পায়রাগুলি","text":[{"type":"poem","text":"নোটন নোটন পায়রাগুলি ঝোঁটন বেঁধেছে\nওপারেতে ছেলেমেয়ে নাইতে নেমেছে।\nদুই পারে দুই রুই কাতলা ভেসে উঠেছে,\nকে দেখেছে? কে দেখেছে? দাদা দেখেছে।\nদাদার হাতে কলম ছিল ছুঁড়ে মেরেছে\nউঃ দাদা! বড্ড লেগেছে।।"}]}},{"id":"1000","type":"passage","label":"হাট্টিমাটিমটিম","data":{"title":"হাট্টিমাটিমটিম","text":[{"type":"poem","text":"হাট্টিমা টিম টিম\nতারা মাঠে পাড়ে ডিম\nতাদের খাড়া দুটো শিং\nতারা হাট্টিমা টিম টিম।।"}]}},{"id":"1100","type":"passage","label":"খোকার প্রশ্ন","data":{"title":"খোকার প্রশ্ন","text":[{"type":"poem","text":"আচ্ছা মাগো, বলো দেখি\nরাত্রি কেন কালো ?\nসুয্যিমামা কোথা থেকে\nপেলেন এমন আলো ?\nফুলগুলো সব নানান রঙের\nকেমন করে হয় ?\nপাতাগুলো সবুজ কেন\nফুলের মতো নয় ?"}]}},{"id":"1200","type":"passage","label":"খোকা যাবে শ্বশুর বাড়ি","data":{"title":"খোকা যাবে শ্বশুর বাড়ি","text":[{"type":"poem","text":"খোকা যাবে শ্বশুর বাড়ি\nসঙ্গে যাবে কে?\nঘরে আছে হুলো বেড়াল\nকোমর বেধেছে।"}]}},{"id":"1300","type":"passage","label":"আমরা দুটি ভাই","data":{"title":"আমরা দুটি ভাই","text":[{"type":"poem","text":"আমরা দুটি ভাই \nশিবের গাজন গাই \nঠাকমা গেছেন গয়া, কাশী \nদুগডুগি বাজাই।"}]}},{"id":"1400","type":"passage","label":"মাসি গো মাসি","data":{"title":"মাসি গো মাসি - সুকুমার রায়","text":[{"type":"poem","text":"মাসি গো মাসি, পাচ্ছে হাসি\nনিম গাছেতে হচ্ছে সিম।\nহাতির মাথায় ব্যাঙের ছাতা।\nকাগের বাসায় বগের ডিম।"}]}},{"id":"1500","type":"passage","label":"মাসি গো মাসি","data":{"title":"মাসি গো মাসি - সুকুমার রায়","text":[{"type":"poem","text":"মাসি গো মাসি, পাচ্ছে হাসি\nনিম গাছেতে হচ্ছে সিম।\nহাতির মাথায় ব্যাঙের ছাতা।\nকাগের বাসায় বগের ডিম।"}]}},{"id":"1600","type":"passage","label":"খোকা যাবে রথে চড়ে","data":{"title":"খোকা যাবে রথে চড়ে","text":[{"type":"poem","text":"খোকা যাবে রথে চড়ে\nব্যাং হবে সারথি ,\nমাটির পুতুল লটর পটর\nপিপড়ে ধরে ছাতি।"}]}},{"id":"1650","type":"passage","label":"সোনা নাচে কোনা","data":{"title":"সোনা নাচে কোনা","text":[{"type":"poem","text":"সোনা নাচে কোনা\nবলদ বাজায় ঢোল।\nসোনার ভাই রেঁধে রেখেছে\nইলিশ মাছের ঝোল।"}]}},{"id":"1700","type":"passage","label":"গড়গড়ার মা লো","data":{"title":"গড়গড়ার মা লো","text":[{"type":"poem","text":"গড়গড়ার মা লো -\nতোর গড়গড়াটা কই?\nহালের গোরু বাঘে খেয়েছে \nপিপড়ে টানে মই।"}]}},{"id":"1800","type":"passage","label":"দোল দোল দুলুনি","data":{"title":"দোল দোল দুলুনি","text":[{"type":"poem","text":"দোল দোল দুলুনি,\nরাঙ্গা মাথায় চিরুনি \nবর আসবে যখনি \nনিয়ে যাবে তখনি।"}]}},{"id":"1900","type":"passage","label":"আয়রে পাখি লেজ ঝোলা","data":{"title":"আয়রে পাখি লেজ ঝোলা","text":[{"type":"poem","text":"আয়রে পাখি লেজ ঝোলা\nখোকার সাথে কর খেলা।\nখাবি-দাবি কলকলাবি\nখোকাকে মোর ঘুম পাড়াবি।  "}]}},{"id":"2000","type":"passage","label":"মামার বাড়ি","data":{"title":"মামার বাড়ি","text":[{"type":"poem","text":"তাই তাই তাই\nমামার বাড়ি যাই,\nমামার বাড়ি ভারি মজা\nকিল চড় নাই।।"}]}}]}