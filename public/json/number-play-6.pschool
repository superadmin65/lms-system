{"label":"Number Play","id":"number-play-6","list":[{"label":"Supercells","type":"numberTable","id":"select-multiples-small-2","onlyBigScreen":true,"commonData":{"start":51,"step":1,"rows":1,"columns":8,"cellSize":90,"fontSize":"2rem","title":"Select the supercells from the below table."},"data":[{"arr":[[43,79,75,63,10,29,28,34]],"answer":[79,29,34]},{"arr":[[200,577,626,345,790,694,109,198]],"answer":[626,790,198]},{"arr":[[6828,670,9435,3780,3708,7308,8000,5583,52]],"answer":[6828,9435,8000]},{"arr":[[2430,7500,7350,9870],[3115,4795,9124,9230],[4580,8632,8280,3446],[5785,1944,5805,6034]],"answer":[7500,9870,8632,5785,6034]}]},{"id":"numberline","label":"Fill the numbers in the numberline","type":"dragAndDrop","onlyBigScreen":true,"commonData":{"width":1100,"height":400,"wordWidth":90,"wordHeight":50,"actWidth":1200,"fontSize":"32px","noOptions":true,"mathKeypad":true,"textStyle":{"fontSize":"32px","width":70,"height":40},"svg":{"props":{"fill":"none","stroke":"black","strokeWidth":1},"paths":["M 60 179 L 60 228  M 130 179 L 130 228  M 200 179 L 200 228  M 270 179 L 270 228  M 340 179 L 340 228  M 410 179 L 410 228  M 480 179 L 480 228  M 550 179 L 550 228  M 620 179 L 620 228  M 690 179 L 690 228  M 760 179 L 760 228  M 830 179 L 830 228  M 900 179 L 900 228  M 970 179 L 970 228  M 1040 179 L 1040 228 ","M 12 202 L 1083 203 M 1068 215 L 1083 203 L 1068 192 M 28 189 L 12 202 L 26 214 "]}},"data":[{"texts":[{"str":"2010","x":445,"y":226},{"str":"2020","x":585,"y":226}],"words":[{"word":"1980","x":10,"y":230},{"word":"1985","x":80,"y":125},{"word":"1990","x":150,"y":230},{"word":"1995","x":220,"y":125},{"word":"2000","x":290,"y":230},{"word":"2005","x":360,"y":125},{"word":"2015","x":500,"y":125},{"word":"2025","x":640,"y":125},{"word":"2030","x":710,"y":230},{"word":"2035","x":780,"y":125},{"word":"2040","x":850,"y":230},{"word":"2045","x":920,"y":125},{"word":"2050","x":990,"y":230}]},{"texts":[{"str":"8593","x":445,"y":226},{"str":"8633","x":585,"y":226}],"words":[{"word":"8473","x":10,"y":230},{"word":"8493","x":80,"y":125},{"word":"8513","x":150,"y":230},{"word":"8533","x":220,"y":125},{"word":"8553","x":290,"y":230},{"word":"8573","x":360,"y":125},{"word":"8613","x":500,"y":125},{"word":"8653","x":640,"y":125},{"word":"8673","x":710,"y":230},{"word":"8693","x":780,"y":125},{"word":"8713","x":850,"y":230},{"word":"8733","x":920,"y":125},{"word":"8753","x":990,"y":230}]},{"texts":[{"str":"3954","x":445,"y":226},{"str":"4154","x":585,"y":226}],"words":[{"word":"3354","x":10,"y":230},{"word":"3454","x":80,"y":125},{"word":"3554","x":150,"y":230},{"word":"3654","x":220,"y":125},{"word":"3754","x":290,"y":230},{"word":"3854","x":360,"y":125},{"word":"4054","x":500,"y":125},{"word":"4254","x":640,"y":125},{"word":"4354","x":710,"y":230},{"word":"4454","x":780,"y":125},{"word":"4554","x":850,"y":230},{"word":"4654","x":920,"y":125},{"word":"4754","x":990,"y":230}]}]},{"type":"numberInput","id":"find-palindrome","label":"Find the Palindrome numbers","data":{"title":"Write all the 3-digit palindrome numbers using the below digits. The numbers should be arranged in ascending order.","fontSize":"1rem","firstLineFontSize":"2rem","list":[{"widths":"200, 200, 200","text":"1, 2, 3\n1. ?0 | 4. ?3 | 7. ?6 \n2. ?1 | 5. ?4 | 8. ?7 \n3. ?2 | 6. ?5 | 9. ?8 \n111, 121, 131, 212, 222, 232, 313, 323, 333"},{"widths":"200, 200, 200","text":"3,5,9\n1. ?0 | 4. ?3 | 7. ?6 \n2. ?1 | 5. ?4 | 8. ?7 \n3. ?2 | 6. ?5 | 9. ?8 \n333, 353, 393, 535, 555, 595, 939, 959, 999"},{"widths":"200, 200, 200","text":"2, 6, 7\n1. ?0 | 4. ?3 | 7. ?6 \n2. ?1 | 5. ?4 | 8. ?7 \n3. ?2 | 6. ?5 | 9. ?8 \n222, 262, 272, 626, 666, 676, 727, 767, 777"}]}},{"type":"numberInput","id":"word-prob","label":"Answer the questions","data":{"fontSize":"1rem","firstLineFontSize":"1rem","list":[{"text":"Pratibha uses the digits 4, 7, 3 & 2 and makes the smallest and largest 4-digit numbers.\nSmallest 4 digit no = ?0\nLargest 4 digit no = ?1\nSum of the two numbers = ?2\nDifference between the two numbers = ?3\n2347, 7432, 9779, 5085\n"},{"text":"Make the smallest and largest number using the digits: 4, 1, 5, 7\nSmallest 4 digit no = ?0\nLargest 4 digit no = ?1\nSum of the two numbers = ?2\nDifference between the two numbers = ?3\n1457, 7541, 8998, 6084\n"},{"text":"The clock shows 10:01. When is the next time, it agains show palindrome time?\n?0 : ?1\n11, 11\n"},{"text":"The clock shows 05:50 When is the next time, it agains show palindrome time?\n?0 : ?1\n10, 01\n"}]}},{"id":"mcq","label":"Find the right option","type":"mcq","data":{"title":"Find the right option.","questions":[{"qText":"Can two acute angles be complement to each other?","options":"Yes, No, Always"},{"qText":"Can two obtuse angles be complement to each other?","options":"No, Yes, Always"},{"qText":"Can two right angles be complement to each other?","options":"No, Yes, Always"},{"qText":"If you make one full rotation about the point you are standing, you have covered ______.","options":"360°, 180°, 90°, 270°"},{"qText":"If you make an 'about turn', you have covered ______.","options":"180°, 90°, 360°, 270°"},{"qText":"You are facing East. If you turn your body so that you face North, you have covered ______.","options":" 90°, 180°, 360°, 270°"}]}},{"id":"mcq-2","label":"Estimate the value","type":"mcq","data":{"title":"Pick the option that may be decent estimation for the given data.","questions":[{"qText":"The distance between Delhi and Mumbai may be ____.","options":"1400 km, 140 km, 14 km"},{"qText":"The maximum number of apples you can carry in your school bag may be _____ .","options":"50, 5, 500"},{"qText":"The cost of a decent android smart phone may be ______.","options":"₹ 10,000\n₹ 1,00,000\n₹ 1000"},{"qText":"The weight of your lunch box may be _____.","options":"500 𝑔, 50 𝑔, 5 𝑘𝑔"},{"qText":"My small waterbottle can hold _____ of water.","options":"400 mL, 40 mL, 4000 mL"}]}},{"label":"Always, Sometimes, Never?","type":"classifySentence","id":"classify","data":{"title":"Classify the below sentence whether they are always true, sometimes true, or never true","types":[{"name":"Always","text":"Adding two odd numbers gives an even number."},{"name":"Never","text":"Adding a 4-digit number and a 2-digit number gives a 6-digit number.\nSubtracting a 2-digit number from a 5-digit number gives a 3-digit number."},{"name":"Sometimes","text":"Adding two 5-digit number gives a 5-digit number.\nAdding a 4-digit number and a 2-digit number gives a 4-digit number.\nSubtracting a 5-digit number from another 5-digit number gives a 5-digit number."}]}},{"label":"Find Negative Numbers","type":"numberLine","id":"find-number","commonData":{"title":"Mark the below number in the numberline.","type":"find"},"data":[{"start":2000,"range":1000,"minorLines":10,"labelGap":100,"unit":150,"text":"2200, 2490, 2620, 2090, 2900"},{"start":2000,"range":2000,"minorLines":10,"labelGap":200,"unit":150,"text":"3000, 2500, 3420, 2840, 3780"},{"start":3000,"range":3500,"minorLines":10,"labelGap":50,"unit":150,"text":"3090, 3150, 3335, 3125, 3465"}]},{"id":"subtract","type":"quickArithmetic","label":"Mental Math","commonData":{"count":10,"title":"Mental Math"},"data":[{"type":"misc~b000+b00"},{"type":"misc~b000-a00"},{"type":"misc~b000+b0"},{"type":"misc~b000-b0"}]}]}