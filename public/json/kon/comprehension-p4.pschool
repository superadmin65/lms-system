                    "data": {
                        "title": "अनुच्छेद को पढ़ें और उत्तर दें। (Read the passage carefully and answer the questions)",
                        "passage": "राहुल और उसकी बहन मीना गाँव में रहते हैं। उनके घर के पास एक बड़ा खेत है। खेत में गेहूँ और चावल उगाए जाते हैं। खेत में एक कुआँ भी है, जिससे पानी लेकर फसल सींची जाती है। हर सुबह राहुल अपने पिताजी की मदद करता है। मीना घर का काम करती है और पढ़ाई में भी बहुत अच्छी है। दोनों भाई-बहन मिलकर गाय को चारा खिलाते हैं और कभी-कभी बछड़े के साथ खेलते हैं। शाम को वे आँगन में खेलते हैं और दादी से कहानियाँ सुनते हैं। रात में पूरा परिवार साथ बैठकर खाना खाता है।",
                        "questions": [
                            {
                                "options": "अच्छी सहेलियाँ\nमाँ-बेटी\nचचेरी बहनें\nअध्यापिका-छात्रा",
                                "qText": "सीमा और रीना का रिश्ता कैसा है?"
                            },
                            {
                                "options": "खेलकूद करना\nचित्रकारी करना\nगाना गाना\nकहानी सुनना",
                                "qText": "सीमा को क्या पसंद है?"
                            },
                            {
                                "options": "चित्रकारी करना\nदौड़ना\nकिताब पढ़ना\nबैडमिंटन खेलना",
                                "qText": "रीना को किस काम में मज़ा आता है?"
                            },
                            {
                                "options": "सहयोगी\nझगड़ालू\nआलसी\nउदासीन",
                                "qText": "दोनों का व्यवहार कैसा था?"
                            },
                            {
                                "options": "उनकी दोस्ती की मिसाल देते हैं\nउनकी दोस्ती अच्छी नहीं है\nवे अकेले रहना पसंद करती हैं\nवे पढ़ाई में कमजोर हैं",
                                "qText": "अध्यापक उनकी दोस्ती के बारे में क्या कहते हैं?"
                            },
                            {
                                "options": "पढ़ाई में\nखेलकूद में\nघर के काम में\nचित्रकारी में",
                                "qText": "मीना किसमें बहुत अच्छी है?"
                            },
                            {
                                "options": "साथ बैठकर खाना खाता है।\nसोने चला जाता है।\nखेत में जाता है।\nगाँव घूमने जाता है।",
                                "qText": "रात को पूरा परिवार क्या करता है?"
                            }
                        ]
                    },
                    "btnLabel": "MCQ"
                }
