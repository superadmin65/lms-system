        {
          "label": "Identify the Tense",
          "id": "1755034847809",
          "type": "classifySentence",
          "data": {
            "title": "वाक्य पढ़ो और उसमें प्रयुक्त काल बताओ।\n(Read the sentence and identify the tense used)",
            "types": [
              {
                "name": "वर्तमान काल",
                "text": "मैं रोज़ सुबह दूध पीता हूँ।\nबच्चे खेल रहे हैं।\nवह रोज़ अख़बार पढ़ता है।\nमैं पढ़ रहा हूँ।"
              },
              {
                "name": "भूतकाल",
                "text": "सीमा कल बाज़ार गई थी।\nमैंने गाना गाया था।\nराम पिछले साल दिल्ली गया था।\nवे कल मेला देखने गए थे।"
              },
              {
                "name": "भविष्य काल",
                "text": "तुम कल आओगे ना?\nहम अगले रविवार पिकनिक पर जाएँगे।"
              }
            ]
          },
          "btnLabel": "Classify Sentence"
        },
        {
          "label": "Choose the Tense",
          "id": "1755035227470",
          "type": "mcq",
          "data": {
            "title": "वाक्यों में से सही विकल्प चुनो। (Choose the correct option from the sentences)",
            "questions": [
              {
                "options": "बच्चे पार्क में खेल रहे हैं।\n बच्चे कल पार्क में खेलने आए हुए थे।\nबच्चे कल पार्क में खेलेंगे।",
                "qText": "*खेलना* (वर्तमान काल)"
              },
              {
                "options": "मैं किताब पढ़ रहा हूँ।\nमैंने किताब पढ़ी।\nमैं कल किताब पढ़ूँगा।",
                "qText": "*पढ़ना* (वर्तमान काल)"
              },
              {
                "options": "वह खाना खा रहा है।\nवह खाना खाएगा।\nउसने खाना खाया।\n",
                "qText": "*खाना* (वर्तमान काल)"
              },
              {
                "options": "अमित ने कल कहानी लिखी।\nअमित रोज़ डायरी लिखता है।\nअमित कल कहानी लिखेगा।",
                "qText": "*लिखना* (भूतकाल)"
              },
              {
                "options": "बच्चे कल मैदान में दौड़ रहे थे।\nबच्चे कल मैदान में दौड़ेंगे।\nबच्चे मैदान में दौड़ रहे हैं।",
                "qText": "*दौड़ना* (भूतकाल)"
              },
              {
                "options": "मोहन ने कल दूध पिया।\nमोहन रोज़ दूध पीता है।\nमोहन कल दूध पिएगा।\n",
                "qText": "*पीना* (भूतकाल)"
              },
              {
                "options": "रीता कल गाना गाएगी। \nरीता रोज़ गाना गाती है।\nरीता ने कल गाना गाया।",
                "qText": "*गाना* (भविष्य काल)"
              },
              {
                "options": "सभी छात्र अगले हफ्ते मंच पर नाचेंगे।\nसभी छात्र रोज़ मंच पर नाचते हैं।\nसभी छात्र कल मंच पर नाचे।",
                "qText": "*नाचना* (भविष्य काल)"
              },
              {
                "options": "लोग यात्रा पर चलेंगे। \nलोग पैदल चलते हैं।\nलोग पैदल चल रहे थे।",
                "qText": "*चलना* (भविष्य काल)"
              }
            ]
          },
          "btnLabel": "MCQ"
        }
      ]
    },
