  "list": [
    {
      "type": "chapter",
      "label": "संज्ञा",
      "altLabel": "Noun",
      "id": "chap-1",
      "desc": "Nouns are words that name people, places, things, or ideas. They can be common or proper, singular or plural, and act as subjects or objects in sentences.",
      "icon": "kon/reading.png",
      "style": {
        "backgroundColor": "#8eccf5"
      },
      "list": [
        {
          "label": "Identify Noun",
          "id": "1755024790478",
          "type": "classifySentence",
          "data": {
            "title": "वाक्य पढ़ो और रेखांकित शब्द की संज्ञा का प्रकार बताओ। \n(Read the sentence and identify the type of the underlined noun)",
            "types": [
              {
                "name": "जातिवाचक संज्ञा",
                "text": "मेरा *दोस्त* बहुत मददगार है।\nहमारा *स्कूल* बहुत बड़ा है।\nहमारा *देश* बहुत सुंदर है।\nबगीचे में बहुत सुंदर *फूल* खिले हैं।"
              },
              {
                "name": "व्यक्तिवाचक संज्ञा",
                "text": "*दिल्ली* भारत की राजधानी है।\n*गंगा* भारत की एक पवित्र नदी है।\n*मोहन* मेरा सबसे अच्छा मित्र है।"
              },
              {
                "name": "भाववाचक संज्ञा",
                "text": "माँ का *प्यार* सबसे अनमोल है।\nउसकी आँखों में *ख़ुशी* चमक रही थी।\nहमें *ईमानदारी* से काम करना चाहिए।"
              }
            ]
          },
          "btnLabel": "Classify Sentence"
        },
        {
          "authored": true,
          "id": "1755026434004",
          "label": "Match the Noun",
          "type": "dragAndDrop",
          "data": {
            "width": 400,
            "words": [
              {
                "x": 243,
                "word": " जातिवाचक संज्ञा",
                "y": 28
              },
              {
                "x": 245,
                "word": "व्यक्तिवाचक संज्ञा",
                "y": 119
              },
              {
                "x": 241,
                "word": "भाववाचक संज्ञा ",
                "y": 220
              }
            ],
            "wordWidth": 70,
            "title": "नीचे दिए गए चित्रों का मिलन उपयुक्त संज्ञा से कीजिए।\n(Match the given pictures with the appropriate nouns)",
