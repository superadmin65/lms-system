    {
      "type": "chapter",
      "label": "काल",
      "altLabel": "Tense",
      "id": "chap-5",
      "desc": "Nouns are words that name people, places, things, or ideas. They can be common or proper, singular or plural, and act as subjects or objects in sentences.",
      "icon": "kon/reading.png",
      "style": {
        "backgroundColor": "#bdbdbd"
      },
      "list": [
        {
          "label": "Match with Tense",
          "id": "1755034274265",
          "type": "match",
          "data": {
            "title": "सही काल से मिलाओ।\n(Match the correct tense)",
