                            {
                                "options": "सफ़ाई ही सेहत है,मेहनती बच्चे,बच्चों की पढ़ाई,अच्छा खेल",
                                "units": "students",
                                "type": "mcq",
                                "value": 40,
                                "qText": "इस गद्यांश का उपयुक्त शीर्षक क्या हो सकता है?"
